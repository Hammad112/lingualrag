# =============================================================
# LingualRAG — environment template
# Copy to .env for local dev. On Render, set these in the dashboard.
# =============================================================

APP_NAME=LingualRAG
APP_ENV=development      # set to "production" on Render
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ── Auth ────────────────────────────────────────────────────────
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database ────────────────────────────────────────────────────
# Local dev:
DATABASE_URL=sqlite+aiosqlite:///./lingualrag.db
# Render production (auto-injected by render.yaml):
# DATABASE_URL=postgresql://user:pass@host/db

# ── Vector store ────────────────────────────────────────────────
# Leave QDRANT_URL blank for local file-based Qdrant.
# In production, point at Qdrant Cloud.
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_PATH=./qdrant_data
QDRANT_COLLECTION=lingualrag_chunks

# ── Embeddings ──────────────────────────────────────────────────
# HuggingFace Inference API — free, no local model.
# Get token at https://huggingface.co/settings/tokens (read access is enough)
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
HF_API_TOKEN=

# ── LLM ─────────────────────────────────────────────────────────
# Free tier at console.groq.com. Empty = extractive fallback (no LLM).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Retrieval ───────────────────────────────────────────────────
TOP_K_DENSE=20
TOP_K_FINAL=5
CHUNK_SIZE=500
CHUNK_OVERLAP=80

# ── OTP ─────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRE_MINUTES=10
OTP_PRINT_TO_CONSOLE=true

# ── Email (Resend) ──────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=noreply@lingualrag.local

# ── Storage ─────────────────────────────────────────────────────
STORAGE_DIR=./storage
# Set to "false" on Render (ephemeral filesystem).
PERSIST_UPLOADS=true

# ── CORS ────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
